# Example environment variables for ai-content-engine
# Copy this file to .env and fill values before running.

# Forge / Manus LLM provider
FORGE_API_KEY=your_forge_api_key_here
# Optional: custom Forge API base URL (if you host a proxy)
FORGE_API_URL=

# Database (MySQL) — used by drizzle
DATABASE_URL=mysql://user:password@localhost:3306/content_ai_db

# App
NODE_ENV=development
PORT=3000
